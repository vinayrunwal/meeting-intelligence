# ============================================================================
# Meeting Intelligence System — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# --- HuggingFace (REQUIRED for PyAnnote diarization) ---
# Get your token at: https://huggingface.co/settings/tokens
# You must also accept terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_your_token_here

# --- Model Configuration ---
# Whisper model: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=large-v3

# FLAN-T5 variant: google/flan-t5-base, google/flan-t5-large, google/flan-t5-xl
FLAN_T5_MODEL=google/flan-t5-large

# Emotion model
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base

# --- Device Configuration ---
# auto, cuda, cpu, mps (Apple Silicon)
DEVICE=auto

# Specific GPU index (for multi-GPU systems)
CUDA_VISIBLE_DEVICES=0

# --- API Configuration ---
FLASK_ENV=production
FLASK_DEBUG=0
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key

# --- File Limits ---
# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=500

# Maximum audio duration in minutes
MAX_AUDIO_DURATION_MIN=120

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Worker Configuration ---
MAX_CONCURRENT_JOBS=3
